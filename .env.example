# Copy this file to .env and fill in your keys

# FMP (Financial Modeling Prep) — free tier: 250 calls/day
# Get key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_key_here

# Anthropic — used by the LLM agent (Milestone 6)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenBB Hub PAT — OPTIONAL, only needed for non-yfinance providers
# Get PAT at: https://my.openbb.co/app/platform/pat
# Leave blank to use yfinance provider (no auth required)
OPENBB_PAT=

# Model selection — change to claude-opus-4-7 for final demo
CLAUDE_MODEL=claude-sonnet-4-6
